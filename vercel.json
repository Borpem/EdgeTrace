{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/broker-csv-trade-analysis/",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/broker-csv-trade-analysis",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/dashboard/",
      "destination": "/app/dashboard",
      "statusCode": 301
    },
    {
      "source": "/upload/",
      "destination": "/app/upload",
      "statusCode": 301
    },
    {
      "source": "/reports/",
      "destination": "/app/reports",
      "statusCode": 301
    },
    {
      "source": "/collections/",
      "destination": "/app/collections",
      "statusCode": 301
    },
    {
      "source": "/compare/",
      "destination": "/app/compare",
      "statusCode": 301
    },
    {
      "source": "/how-it-works/",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/demo/",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/sample-report/",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/dashboard",
      "destination": "/app/dashboard",
      "statusCode": 301
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/app/dashboard/:path*",
      "statusCode": 301
    },
    {
      "source": "/upload",
      "destination": "/app/upload",
      "statusCode": 301
    },
    {
      "source": "/reports",
      "destination": "/app/reports",
      "statusCode": 301
    },
    {
      "source": "/collections",
      "destination": "/app/collections",
      "statusCode": 301
    },
    {
      "source": "/collections/:path*",
      "destination": "/app/collections/:path*",
      "statusCode": 301
    },
    {
      "source": "/compare",
      "destination": "/app/compare",
      "statusCode": 301
    },
    {
      "source": "/compare/:path*",
      "destination": "/app/compare/:path*",
      "statusCode": 301
    },
    {
      "source": "/how-it-works",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/demo",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/sample-report",
      "destination": "/",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://*.clerk.accounts.dev https://*.clerk.com https://clerk.edgetrace.app https://js.stripe.com; worker-src 'self' blob:; connect-src 'self' https://edgetrace-production.up.railway.app https://*.clerk.accounts.dev https://*.clerk.com https://clerk.edgetrace.app https://api.clerk.com https://*.stripe.com https://api.stripe.com; frame-src https://js.stripe.com https://hooks.stripe.com https://*.clerk.accounts.dev https://*.clerk.com https://clerk.edgetrace.app; form-action 'self' https://*.stripe.com; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/brand/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/graphics/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/marketing/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/app",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/app/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/login",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/login/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/signup",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/signup/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/404",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/brand/atlas-brand-sheet",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/brand/edgetrace-brand-sheet",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/shells/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/sample-:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://edgetrace-production.up.railway.app/api/:path*"
    },
    {
      "source": "/app",
      "destination": "/shells/app"
    },
    {
      "source": "/app/:path*",
      "destination": "/shells/app"
    },
    {
      "source": "/login",
      "destination": "/shells/login"
    },
    {
      "source": "/login/:path*",
      "destination": "/shells/login"
    },
    {
      "source": "/signup",
      "destination": "/shells/signup"
    },
    {
      "source": "/signup/:path*",
      "destination": "/shells/signup"
    }
  ]
}

# EdgeTrace authentication mode.
# Use mock for local tests without Clerk keys. Use clerk for real authenticated app sessions.
VITE_AUTH_MODE=mock
AUTH_MODE=mock

# Public app URL used for CORS, billing redirects, and production route protection.
# Set both to your deployed frontend origin in production.
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

# Clerk authentication.
# Required when VITE_AUTH_MODE=clerk / AUTH_MODE=clerk, and required in production.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe billing.
# Required only when enabling checkout, customer portal, and subscription webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ADVANCED_PRICE_ID=
VITE_STRIPE_PUBLIC_KEY=

# Database provider. Use sqlite locally; production deployment requires postgres.
DATABASE_PROVIDER=sqlite

# Required when DATABASE_PROVIDER=postgres.
DATABASE_URL=

# Optional SQLite path. For local/beta SQLite, use a persistent volume if deployed.
EDGETRACE_DB_PATH=

# Optional frontend API override for deployed split frontend/backend setups.
VITE_API_BASE_URL=

{
  "name": "edgetrace-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:e2e": "node scripts/dev-e2e.mjs",
    "dev:test": "node scripts/dev-test.mjs",
    "dev:web": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build && tsx scripts/prerender.tsx",
    "validate:env": "tsx scripts/validateEnv.ts",
    "test:imports": "tsx scripts/testBrokerAdapters.ts",
    "test:smoke": "node scripts/smoke.mjs",
    "test:security": "tsx scripts/testSecurityIsolation.ts",
    "test:db:postgres": "node scripts/testPostgresDb.mjs",
    "test:e2e": "node scripts/runE2e.mjs",
    "test:seo": "npm run build && npm run test:seo:run",
    "test:seo:run": "node scripts/runSeoTests.mjs",
    "test:seo:full": "npm run test:seo",
    "test:all": "npm run validate:env && npm run build && npm run test:seo:run && npm run test:imports && npm run test:security && npm run test:smoke && npm run test:e2e",
    "test:all:postgres": "npm run validate:env && npm run build && npm run test:imports && npm run test:security && npm run test:smoke && npm run test:db:postgres",
    "preview": "vite preview --host 0.0.0.0",
    "start": "tsx server/index.ts",
    "start:server": "tsx server/index.ts"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.6",
    "@clerk/express": "^2.1.15",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.3.0",
    "stripe": "^22.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.2",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18"
  }
}
